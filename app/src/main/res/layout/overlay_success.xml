<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/success_overlay_bg"
    android:elevation="10dp"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_overlay_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Action Successful"
        android:textColor="@color/status_confirmed_text"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_overlay_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Your changes have been saved."
        android:textColor="@color/text_dark"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_overlay_title" />

    <Button
        android:id="@+id/btn_overlay_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/primary_blue"
        android:text="Home"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/tv_overlay_msg" />

    <Button
        android:id="@+id/btn_overlay_undo"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Undo"
        android:textAllCaps="false"
        android:textColor="@color/text_gray"
        app:layout_constraintTop_toBottomOf="@id/btn_overlay_home"
        app:strokeColor="@color/border_gray" />

</androidx.constraintlayout.widget.ConstraintLayout>
